{
  "name": "docsourcing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:migrate": "node db/migrate.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "next": "16.2.4",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.11.0",
    "eslint-config-next": "16.2.4",
    "typescript": "^5.6.0"
  }
}
